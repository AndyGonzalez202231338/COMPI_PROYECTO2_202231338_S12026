{
  "name": "yfera-ide",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:parser": "jison src/app/grammars/y.jison -o src/generated/y-parser.js && node scripts/generate-parser-types.cjs",
    "build:all": "npm run build:parser && ng build",
    "build:parsers": "jison src/app/grammars/comp.jison -o src/generated/comp.js && jison src/app/grammars/y.jison -o src/generated/y.js",
    "build:comp": "jison src/app/grammars/comp.jison -o src/generated/comp.js",
    "build:y": "jison src/app/grammars/y.jison -o src/generated/y.js",
    "dev": "concurrently \"npm run backend\" \"npm start\"",
    "backend": "cd ../backend && npm start"
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/ssr": "^20.0.0",
    "bootstrap-icons": "^1.13.1",
    "express": "^4.18.2",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^18.18.0",
    "concurrently": "^8.0.0",
    "jasmine-core": "^6.2.0",
    "jison": "^0.4.18",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "typescript": "~5.8.0"
  }
}
